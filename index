function checkMC(correctId,chosenId,btn){
  if(answered)return;answered=true;
  const correct=chosenId===correctId;
  const btns=document.querySelectorAll('.option-btn');
  btns.forEach(b=>{b.style.pointerEvents='none';});
  recordMastery(gameQuestions[currentQ].vocab.id,correct);
  bumpStreak(correct);
  if(correct){
    btn.classList.add('correct');bumpScore();playDing();showConfetti();
    showToast('✅ Chính xác!','success');
  }else{
    btn.classList.add('wrong');playBuzz();
    btns.forEach(b=>{if(b.textContent.includes(VOCAB.find(v=>v.id===correctId).en))b.classList.add('correct')});
    showToast('❌ Sai rồi! Xem giải thích bên dưới','error');
  }
  refreshStreakTag();
  showExplanation(gameQuestions[currentQ].vocab,correct);showNextBtn();
}

