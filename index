ance"], "collocationVi": ["phát minh tiết kiệm sức lao động", "thiết bị tiết kiệm sức lao động"], "synonyms": ["time-saving", "efficient"], "synonymsVi": ["tiết kiệm thời gian", "hiệu quả"], "antonyms": ["labor-intensive"], "antonymsVi": ["tốn nhiều sức lao động"], "wordFamily": ["labor (n) - lao động", "laborious (adj) - vất vả, tốn công", "laborer (n) - người lao động"], "wordFamilyVi": ["lao động", "vất vả, tốn nhiều công sức", "người lao động chân tay"], "example": "The washing machine is one of the most influential labor-saving inventions of the 20th century.", "exampleVi": "Máy giặt là một trong những phát minh tiết kiệm sức lao động có ảnh hưởng nhất thế kỷ 20."}, {"id": 13, "topic": "📚 Tổng hợp Listening & Reading A", "en": "labor-saving device", "ipa": "/ˈleɪbə ˈseɪvɪŋ dɪˈvaɪs/", "pos": "n", "vi": "thiết bị tiết kiệm công sức", "enDef": "A machine or tool that reduces the amount of physical effort needed to complete a task.", "usage": "Noun phrase, often plural 'labor-saving devices'.", "collocations": ["household labor-saving device", "invest in labor-saving devices"], "collocationVi": ["thiết bị tiết kiệm công sức trong gia đình", "đầu tư vào thiết bị tiết kiệm công sức"], "synonyms": ["time-saving appliance"], "synonymsVi": ["thiết bị tiết kiệm thời gian"], "antonyms": ["labor-intensive method"], "antonymsVi": ["phương pháp tốn nhiều sức lao động"], "wordFamily": ["labor-saving (adj)"], "wordFamilyVi": ["tiết kiệm sức lao động"], "example": "Dishwashers and vacuum cleaners are common labor-saving devices found in most modern homes.", "exampleVi": "Máy rửa bát và máy hút bụi là những thiết bị tiết kiệm công sức phổ biến trong các gia đình hiện đại."}, {"id": 14, "topic": "📚 Tổng hợp Listening & Reading A", "en": "labor-saving technology", "ipa": "/ˈleɪbə ˈseɪvɪŋ tekˈnɒlədʒi/", "pos": "n", "vi": "công nghệ tiết kiệm lao động", "enDef": "Technology that reduces the human effort required to perform tasks.", "usage": "Noun phrase used in essays about automati