              <span class="tag" style="background:var(--bg);color:var(--dark);font-size:10px">${v.pos||'phr'}</span>
            </div>
            <div class="flex items-center flex-wrap gap-2">
              <span class="font-700 text-base text-dark2">${v.en}</span>
              ${v.ipa?`<span class="text-xs text-soft">${v.ipa}</span>`:''}
            </div>
            <p class="text-sm font-600 mt-1" style="color:var(--accent)">${viDisplay(v.vi)}</p>
          </div>
          <div class="flex flex-col items-center gap-2 flex-shrink-0 pt-1">
            <button
              onclick="event.preventDefault();event.stopPropagation();toggleBookmark(${v.id});updateStarVisual(this,isBookmarked(${v.id}))"
              class="star-btn ${isBookmarked(v.id)?'active':''}"
              title="Đánh dấu yêu thích">
              ${isBookmarked(v.id)?ICONS.starFilled:ICONS.starEmpty}
            </button>
            <span class="chevron-wrap" style="color:var(--accent)">${ICONS.chevronDown}</span>
          </div>
        </div>
      </summary>
      <div class="mt-2" id="detailSlot-${v.id}">
        <div class="text-center py-5 text-soft text-sm">
          <div class="spinner mx-auto mb-2" style="width:20px;height:20px;border-width:2px"></div>Đang tải chi tiết...
        </div>
      </div>
    </details>
  </div>`).join('');
}

function lazyRenderDetail(detailsEl, id){
  if(!detailsEl.open) return;
  const slot = document.getElementById('detailSlot-'+id);
  if(!slot || slot.dataset.loaded==='1') return;
