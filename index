    </button>
  </div>`;
}

function masteredCount(){
  return Object.keys(mastery).filter(id=>mastery[id].correct>=2 && mastery[id].correct>mastery[id].wrong).length;
}

function badgeForPct(pct){
  if(pct>=95)return {cls:'badge-master',label:'👑 Master'};
  if(pct>=80)return {cls:'badge-gold',label:'🥇 Vàng'};
  if(pct>=50)return {cls:'badge-silver',label:'🥈 Bạc'};
  if(pct>0)return {cls:'badge-bronze',label:'🥉 Đồng'};
  return {cls:'badge-locked',label:'Chưa mở khoá'};
}

