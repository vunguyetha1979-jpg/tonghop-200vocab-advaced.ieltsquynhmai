function debouncedFilter(term){
  clearTimeout(searchDebounceTimer);
  searchDebounceTimer = setTimeout(()=>{ filterVocab(term); }, 250);
}

function clearSearch(){
  vocabFilterText='';
  vocabPage=0;
  currentScreen='vocab';
  render();
}

function filterVocab(term){
  vocabFilterText=term;
  vocabPage=0;
  const filtered=applyVocabFilters();
  const pageSlice=filtered.slice(0, VOCAB_PAGE_SIZE);
  const container=document.getElementById('vocabContainer');
  if(!container) return;
  container.innerHTML=renderVocabCards(pageSlice);
  // update count
  const countEl=document.querySelector('.text-xs.text-soft.mb-3');
  if(countEl) countEl.textContent = filtered.length===VOCAB.length
    ? `Hiển thị ${Math.min(pageSlice.length, filtered.length)} / ${filtered.length} từ`
    : `Tìm thấy ${filtered.length} từ — hiển thị ${pageSlice.length}`;
  // update load-more
  const moreArea=document.querySelector('.text-center.mt-4.mb-6, .text-center.text-xs.text-soft.mt-6.mb-4');
  if(moreArea){
    if(pageSlice.length < filtered.length){
      moreArea.className='text-center mt-4 mb-6';
      moreArea.innerHTML=`<button onclick="loadMoreVocab()" class="btn-primary ripple-btn px-8">Xem thêm ${Math.min(VOCAB_PAGE_SIZE, filtered.length - pageSlice.length)} từ nữa ↓</button>`;
    } else {
      moreArea.className='text-center text-xs text-soft mt-6 mb-4';
      moreArea.textContent=`✅ Đã hiển thị tất cả ${filtered.length} từ`;
    }
  }
  // update X clear button
  const inp=document.getElementById('vocabSearch');
  if(inp) inp.value=term;
  const xBtn=document.querySelector('button[title="Xóa tìm kiếm"]');
  if(term && !xBtn){
    const wrap=inp && inp.parentElement;
    if(wrap){
      const b=document.createElement('button');
      b.setAttribute('title','Xóa tìm kiếm');
      b.setAttribute('onclick','clearSearch()');
      b.style.cssText='position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;font-size:18px;cursor:pointer;color:var(--text-soft)';
      b.textContent='✕';
      wrap.appendChild(b);
    }
  } else if(!term && xBtn){ xBtn.remove(); }
}

