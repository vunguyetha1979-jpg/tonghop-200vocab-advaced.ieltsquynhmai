.slide-in{animation:slideIn .45s cubic-bezier(.34,1.56,.64,1)}
@keyframes slideIn{from{opacity:0;transform:translateX(40px)}to{opacity:1;transform:translateX(0)}}
.pop-in{animation:popIn .5s cubic-bezier(.34,1.56,.64,1)}
@keyframes popIn{0%{opacity:0;transform:scale(.6) rotate(-8deg)}60%{opacity:1;transform:scale(1.08) rotate(2deg)}100%{transform:scale(1) rotate(0)}}
.bounce-in{animation:bounceIn .6s cubic-bezier(.34,1.56,.64,1)}
@keyframes bounceIn{0%{opacity:0;transform:translateY(-30px) scale(.8)}50%{opacity:1;transform:translateY(8px) scale(1.04)}100%{transform:translateY(0) scale(1)}}
.float{animation:float 3s ease-in-out infinite}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
.shake{animation:shake .45s ease}
@keyframes shake{0%,100%{transform:translateX(0)}20%{transform:translateX(-10px)}40%{transform:translateX(10px)}60%{transform:translateX(-6px)}80%{transform:translateX(6px)}}
.card-hover{transition:transform .25s ease,box-shadow .25s ease}
.card-hover:hover{transform:translateY(-3px) scale(1.01);box-shadow:0 10px 28px rgba(0,0,0,.13)}
.btn-primary{background:var(--accent);color:#fff;border:none;border-radius:12px;padding:12px 28px;font-weight:600;cursor:pointer;transition:all .2s ease;position:relative;overflow:hidden}
.btn-primary:hover{filter:brightness(1.1);transform:translateY(-2px) scale(1.03);box-shadow:0 6px 16px rgba(69,123,157,.35)}
.btn-primary:active{transform:scale(.97)}
.btn-pink{background:var(--pink);color:var(--dark);border:none;border-radius:12px;padding:12px 28px;font-weight:600;cursor:pointer;transition:all .2s ease}
.btn-pink:hover{filter:brightness(.95);transform:translateY(-2px) scale(1.03);box-shadow:0 6px 16px rgba(255,175,204,.45)}
.btn-pink:active{transform:scale(.97)}
.progress-bar{height:8px;background:#e0e0e0;border-radius:9999px;overflow:hidden}
.progress-fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--pink));border-radius:9999px;transition:width .6s cubic-bezier(.4,0,.2,1);position:relative;overflow:hidden}
.progress-fill::after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(255,255,255,.45),transparent);animation:shimmer 1.8s infinite}
@keyframes shimmer{0%{transform:translateX(-100%)}100%{transform:translateX(100%)}}
.option-btn{border:2px solid #ddd;border-radius:12px;padding:14px 18px;cursor:pointer;transition:all .18s ease;background:var(--card-bg);color:var(--dark);text-align:left;width:100%;font-size:15px;transform:scale(1)}
.option-btn:hover:not(:disabled){border-color:var(--accent);background:#f0f8ff;transform:translateX(4px) scale(1.01);box-shadow:0 4px 12px rgba(69,123,157,.15)}
[data-theme="dark"] .option-btn:hover:not(:disabled){background:#1c3147}
.option-btn.correct{border-color:var(--success);background:#d4edda;color:#1a2a3a;animation:correctPulse .5s ease}
.option-btn.wrong{border-color:var(--error);background:#f8d7da;color:#1a2a3a;animation:shake .45s ease}
@keyframes correctPulse{0%{transform:scale(1)}40%{transform:scale(1.04)}100%{transform:scale(1)}}
@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.02)}}
.confetti{position:fixed;pointer-events:none;z-index:9999;inset:0}
.tag{display:inline-block;padding:3px 10px;border-radius:20px;font-size:12px;font-weight:500}
.input-field{border:2px solid #ddd;border-radius:12px;padding:12px 16px;font-size:16px;width:100%;transition:all .2s ease;outline:none}
.input-field:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(69,123,157,.15)}
.toast{position:fixed;top:20px;left:50%;transform:translateX(-50%);padding:12px 24px;border-radius:12px;color:#fff;font-weight:600;z-index:9999;animation:toastIn .4s ease,toastOut .4s ease 2.1s forwards;box-shadow:0 8px 20px rgba(0,0,0,.18)}
@keyframes toastIn{from{opacity:0;transform:translateX(-50%) translateY(-24px) scale(.9)}to{opacity:1;transform:translateX(-50%) translateY(0) scale(1)}}
@keyframes toastOut{to{opacity:0;transform:translateX(-50%) translateY(-16px) scale(.95)}}
.vocab-card{background:var(--card-bg);color:var(--dark);border-radius:16px;padding:20px;margin-bottom:0;border-left:4px solid var(--accent);transition:all .25s ease;box-shadow:var(--shadow-soft)}
.section-tag{font-size:11px;text-transform:uppercase;letter-spacing:1px;font-weight:700}
.spinner{width:40px;height:40px;border:3px solid #e0e0e0;border-top:3px solid var(--accent);border-radius:50%;animation:spin 1s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.score-pop{display:inline-block;animation:scorePop .4s cubic-bezier(.34,1.56,.64,1)}
@keyframes scorePop{0%{transform:scale(1)}50%{transform:scale(1.35)}100%{transform:scale(1)}}
.icon-spin:hover{animation:spin .6s ease}
.home-emoji{animation:float 3.5s ease-in-out infinite}
.next-btn-enter{animation:bounceIn .45s cubic-bezier(.34,1.56,.64,1)}
@keyframes glow{0%,100%{box-shadow:0 0 0 0 rgba(255,215,0,.5)}50%{box-shadow:0 0 0 8px rgba(255,215,0,0)}}
.master-glow{animation:glow 1.8s ease-in-out infinite}
details > summary{list-style:none}
details > summary::-webkit-details-marker{display:none}
details[open] summary i[data-lucide="chevron-down"]{transform:rotate(180deg);transition:transform .25s ease}
summary i[data-lucide="chevron-down"]{transition:transform .25s ease}

:root{
  --bg:#A8DADC;--white:#FFFFFF;--pink:#FFAFCC;--dark:#1a2a3a;--accent:#457B9D;--success:#2ecc71;--error:#e74c3c;
  --card-bg:#ffffff;--page-bg-1:#A8DADC;--page-bg-2:#e8f4f8;--page-bg-3:#FFAFCC33;--text-soft:rgba(26,42,58,.65);
  --gold:#FFD166;--bronze:#CD8A4D;--silver:#C7CBD1;--platinum:#7DD3E0;
  --shadow-soft:0 4px 16px rgba(26,42,58,.08);--shadow-mid:0 10px 28px rgba(26,42,58,.12);
}
[data-theme="dark"]{
  --bg:#0f1b2a;--white:#16263a;--pink:#FF9FC1;--dark:#eef3f7;--accent:#6fb3da;--success:#3ddc84;--error:#ff6b6b;
  --card-bg:#16263a;--page-bg-1:#0a131e;--page-bg-2:#0f1b2a;--page-bg-3:#1c2c40;--text-soft:rgba(238,243,247,.65);
  --shadow-soft:0 4px 16px rgba(0,0,0,.35);--shadow-mid:0 10px 28px rgba(0,0,0,.45);
}
body{background:linear-gradient(135deg,var(--page-bg-1) 0%,var(--page-bg-2) 50%,var(--page-bg-3) 100%);transition:background .4s ease;color:var(--dark)}
.bgblob{position:fixed;border-radius:50%;filter:blur(60px);opacity:.35;z-index:0;pointer-events:none;animation:blobFloat 14s ease-in-out infinite}
@keyframes blobFloat{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(20px,-30px) scale(1.08)}}
.glass{background:color-mix(in srgb, var(--card-bg) 88%, transparent);backdrop-filter:blur(10px);border:1px solid color-mix(in srgb, var(--accent) 12%, transparent)}
.surface{background:var(--card-bg);transition:background .3s ease,color .3s ease}
.text-dark2{color:var(--dark)}
.text-soft{color:var(--text-soft)}
.app-shell{position:relative;z-index:1}

/* Theme + sound toggle pills */
.icon-toggle{width:38px;height:38px;border-radius:12px;display:flex;align-items:center;justify-content:center;background:var(--card-bg);box-shadow:var(--shadow-soft);cursor:pointer;transition:all .2s ease;border:none}
.icon-toggle:hover{transform:translateY(-2px) scale(1.05)}
.icon-toggle:active{transform:scale(.93)}

/* Streak flame */
.streak-chip{display:inline-flex;align-items:center;gap:4px;background:linear-gradient(90deg,#ff9966,#ff5e62);color:#fff;padding:4px 12px;border-radius:999px;font-weight:700;font-size:13px;box-shadow:0 4px 12px rgba(255,94,98,.35)}
.streak-flame{animation:flameFlicker 1.1s ease-in-out infinite}
@keyframes flameFlicker{0%,100%{transform:scale(1) rotate(-2deg)}50%{transform:scale(1.15) rotate(2deg)}}
.streak-bump{animation:streakBump .45s cubic-bezier(.34,1.56,.64,1)}
@keyframes streakBump{0%{transform:scale(1)}45%{transform:scale(1.3) rotate(-4deg)}100%{transform:scale(1)}}

/* Badges */
.badge{display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:999px;font-weight:700;font-size:12px;box-shadow:var(--shadow-soft)}
.badge-bronze{background:linear-gradient(135deg,#CD8A4D,#a86a32);color:#fff}
.badge-silver{background:linear-gradient(135deg,#E8EAED,#C7CBD1);color:#2a2a2a}
.badge-gold{background:linear-gradient(135deg,#FFD166,#F4A300);color:#5c3d00}
.badge-master{background:linear-gradient(135deg,#9b5de5,#5e3aa6);color:#fff;animation:masterShimmer 2.2s ease-in-out infinite}
@keyframes masterShimmer{0%,100%{box-shadow:0 0 0 0 rgba(155,93,229,.5)}50%{box-shadow:0 0 0 10px rgba(155,93,229,0)}}
.badge-locked{background:#e9edf0;color:#9aa5ab}
[data-theme="dark"] .badge-locked{background:#1d2c3d;color:#5c6b78}

/* Filter pills */
.pill{padding:7px 16px;border-radius:999px;font-size:13px;font-weight:600;border:2px solid transparent;cursor:pointer;transition:all .18s ease;background:var(--card-bg);color:var(--text-soft);box-shadow:var(--shadow-soft)}
.pill.active{background:var(--accent);color:#fff;border-color:var(--accent)}
.pill:hover:not(.active){transform:translateY(-1px)}

/* Bookmark star */
.star-btn{cursor:pointer;transition:transform .25s cubic-bezier(.34,1.56,.64,1),color .2s ease;color:#cfd6da;background:none;border:none;padding:2px}
.star-btn:hover{transform:scale(1.15)}
.star-btn.active{color:#FFC247;animation:starPop .4s cubic-bezier(.34,1.56,.64,1)}
@keyframes starPop{0%{transform:scale(1)}50%{transform:scale(1.4) rotate(-15deg)}100%{transform:scale(1)}}

/* Flashcard 3D */
.flip-scene{perspective:1400px}
.flip-card{position:relative;width:100%;min-height:340px;transform-style:preserve-3d;transition:transform .55s cubic-bezier(.45,.05,.15,1);cursor:pointer}
.flip-card.flipped{transform:rotateY(180deg)}
.flip-face{position:absolute;inset:0;backface-visibility:hidden;border-radius:20px;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:28px;box-shadow:var(--shadow-mid)}
.flip-front{background:linear-gradient(135deg,var(--accent),#5b9bc4);color:#fff}
.flip-back{background:var(--card-bg);transform:rotateY(180deg);overflow-y:auto;text-align:left;align-items:stretch;color:var(--dark)}
.know-btn{border-radius:14px;padding:14px;font-weight:700;cursor:pointer;border:none;transition:all .2s ease;font-size:15px}
.know-btn.no{background:#fde2e2;color:#c0392b}
.know-btn.no:hover{background:#fbc7c7;transform:translateY(-2px)}
.know-btn.yes{background:#d7f5e0;color:#1f8a4c}
.know-btn.yes:hover{background:#bdeeca;transform:translateY(-2px)}

/* Stats dashboard */
.stat-card{background:var(--card-bg);border-radius:18px;padding:18px;box-shadow:var(--shadow-soft);text-align:center;transition:transform .2s ease}
.stat-card:hover{transform:translateY(-3px)}
.stat-num{font-size:28px;font-weight:800;color:var(--accent)}

/* Detail / explanation accordion sections */
.kb-section{border-radius:14px;padding:14px;margin-bottom:12px;border:1px solid color-mix(in srgb, var(--accent) 18%, transparent)}
.kb-chip{display:inline-block;padding:3px 10px;border-radius:7px;font-weight:600;font-size:13px}
.kb-row{display:flex;align-items:baseline;gap:8px;flex-wrap:wrap;margin-bottom:6px;font-size:14px}
.kb-row:last-child{margin-bottom:0}

/* Screen transitions */
.screen-enter{animation:screenIn .35s cubic-bezier(.22,1,.36,1)}
@keyframes screenIn{from{opacity:0;transform:translateY(10px) scale(.99)}to{opacity:1;transform:translateY(0) scale(1)}}

/* Empty state */
.empty-state{text-align:center;padding:48px 20px;opacity:.7}

/* Ripple */
.ripple-btn{position:relative;overflow:hidden}
.ripple{position:absolute;border-radius:50%;background:rgba(255,255,255,.55);transform:scale(0);animation:rippleAnim .6s ease-out forwards;pointer-events:none}
@keyframes rippleAnim{to{transform:scale(3.2);opacity:0}}

/* Scrollbar polish */
::-webkit-scrollbar{width:8px;height:8px}
::-webkit-scrollbar-thumb{background:color-mix(in srgb, var(--accent) 40%, transparent);border-radius:8px}

/* responsive helpers */
@media (max-width:480px){
  .flip-card{min-height:380px}
}

  </style>
