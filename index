function renderFlashcards(app){
  if(flash.idx>=flash.list.length){
    const total=flash.list.length;
    const pct=total?Math.round(flash.known/total*100):0;
    if(pct>=70)showConfetti(true);
    app.innerHTML=`
    ${topBar()}
    <div class="app-shell flex flex-col items-center justify-center min-h-full p-6 fade-in">
      <div class="text-6xl mb-4 bounce-in">🃏</div>
      <h2 class="text-2xl font-800 mb-2 text-dark2">Hoàn thành phiên Flashcard!</h2>
      <p class="text-soft mb-1">Đã thuộc: <strong style="color:var(--success)">${flash.known}</strong> / Chưa thuộc: <strong style="color:var(--error)">${flash.unknown}</strong></p>
      <div class="w-full max-w-xs my-4"><div class="progress-bar" style="height:12px"><div class="progress-fill" style="width:${pct}%"></div></div></div>
      <div class="space-y-3 w-full max-w-xs">
        ${flash.unknown>0?`<button onclick="reviewUnknown()" class="w-full ripple-btn py-3 rounded-xl font-700" style="background:linear-gradient(90deg,#FF8A3D,#FFC247);color:#fff">📚 Ôn lại ${flash.unknown} từ chưa thuộc</button>`:''}
        <button onclick="startFlashcards(false)" class="btn-primary w-full ripple-btn">🔄 Học lại từ đầu</button>
        <button onclick="currentScreen='home';render()" class="btn-pink w-full ripple-btn">🏠 Về trang chủ</button>
      </div>
    </div>`;
    safeLucide();return;
  }
  const v=flash.list[flash.idx];
  const fav=isBookmarked(v.id);
  app.innerHTML=`
  ${topBar()}
  <div class="app-shell min-h-full p-4 fade-in">
    <div class="max-w-lg mx-auto">
      <div class="flex items-center justify-between mb-3">
        <button onclick="currentScreen='home';render()" class="p-2 rounded-lg surface ripple-btn" style="box-shadow:var(--shadow-soft)">${ICONS.arrowLeft}</button>
        <span class="font-700 text-sm text-dark2">🃏 Flashcard</span>
        <span class="text-sm font-600 px-3 py-1 rounded-full surface text-dark2" style="box-shadow:var(--shadow-soft)">${flash.idx+1}/${flash.list.length}</span>
      </div>
      <div class="progress-bar mb-4"><div class="progress-fill" style="width:${(flash.idx/flash.list.length)*100}%"></div></div>

      <div class="flip-scene mb-4">
        <div class="flip-card ${flash.flipped?'flipped':''}" id="flipCardEl" onclick="flipCard()">
          <div class="flip-face flip-front">
            <span class="tag mb-3" style="background:rgba(255,255,255,.25);color:#fff">${v.topic}</span>
            <p class="text-3xl font-800 mb-2 text-center">${v.en}</p>
            ${v.ipa?`<p class="text-sm opacity-80 mb-1">${v.ipa}</p>`:''}
            <span class="tag" style="background:rgba(255,255,255,.25);color:#fff">${v.pos||'phr'}</span>
            <p class="text-xs opacity-75 mt-5">👆 Chạm để xem nghĩa</p>
          </div>
          <div class="flip-face flip-back">
            <p class="font-800 text-xl mb-2 text-dark2">${viDisplay(v.vi)}</p>
            <p class="text-sm text-soft mb-3">${v.enDef}</p>
            <div class="rounded-lg p-3 mb-2" style="background:var(--bg)">
              <p class="text-xs font-700 mb-1" style="color:var(--accent)">VÍ DỤ</p>
              <p class="text-sm text-dark2">${v.example}</p>
              <p class="text-sm text-soft mt-1">${v.exampleVi}</p>
            </div>
            <p class="text-xs text-soft mt-auto">👆 Chạm để lật lại</p>
          </div>
        </div>
      </div>

      <div class="flex items-center justify-center gap-3 mb-4">
        <button onclick="event.stopPropagation();speakWord('${v.en.replace(/'/g,"\\'")}')" class="icon-toggle">${ICONS.volumeOn}</button>
        <button onclick="event.stopPropagation();toggleBookmark(${v.id});updateStarVisual24(this,isBookmarked(${v.id}))" class="star-btn ${fav?'active':''}">${fav?ICONS.starFilled24:ICONS.starEmpty24}</button>
      </div>

      <div class="grid grid-cols-2 gap-3">
        <button class="know-btn no ripple-btn" onclick="markFlash(false)">😕 Chưa thuộc</button>
        <button class="know-btn yes ripple-btn" onclick="markFlash(true)">😎 Đã thuộc</button>
      </div>
    </div>
  </div>`;
  safeLucide();
}

function flipCard(){
  flash.flipped=!flash.flipped;
  const el=document.getElementById('flipCardEl');
  if(el)el.classList.toggle('flipped');
}

function markFlash(known){
  const v=flash.list[flash.idx];
  recordMastery(v.id,known);
  if(known){flash.known++;playDing();}else{flash.unknown++;flash.session.push(v);playBuzz();}
  flash.idx++;flash.flipped=false;
  persistState();
  render();
}

function reviewUnknown(){
  flash={list:shuffle(flash.session),idx:0,flipped:false,known:0,unknown:0,session:[]};
  render();
}

// ===== STATS DASHBOARD =====
function renderStats(app){
  const total=VOCAB.length;
  const mastered=masteredCount();
  const accuracy = totalAnswered>0 ? Math.round(totalCorrect/totalAnswered*100) : 0;
  const avgProgress=Math.round((progress.p1+progress.p2+progress.p3+progress.p4)/4);
  const topicCounts={};
  VOCAB.forEach(v=>{topicCounts[v.topic]=(topicCounts[v.topic]||0)+1});
  const masteredByTopic={};
  VOCAB.forEach(v=>{
    if(mastery[v.id] && mastery[v.id].correct>=2 && mastery[v.id].correct>mastery[v.id].wrong){
      masteredByTopic[v.topic]=(masteredByTopic[v.topic]||0)+1;
    }
  });
  app.innerHTML=`
  ${topBar()}
  <div class="app-shell min-h-full p-4 fade-in">
    <div class="max-w-2xl mx-auto">
      <div class="flex items-center gap-3 mb-5">
        <button onclick="currentScreen='home';render()" class="p-2 rounded-lg surface ripple-btn" style="box-shadow:var(--shadow-soft)">${ICONS.arrowLeft}</button>
        <h2 class="text-xl font-700 text-dark2">📊 Thống kê học tập</h2>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
        <div class="stat-card"><div class="stat-num">${total}</div><div class="text-xs text-soft mt-1">Tổng số từ</div></div>
        <div class="stat-card"><div class="stat-num">${mastered}</div><div class="text-xs text-soft mt-1">Đã thành thạo</div></div>
        <div class="stat-card"><div class="stat-num">${accuracy}%</div><div class="text-xs text-soft mt-1">Độ chính xác</div></div>
        <div class="stat-card"><div class="stat-num">${bestStreak}</div><div class="text-xs text-soft mt-1">🔥 Chuỗi kỷ lục</div></div>
      </div>

      <div class="surface rounded-2xl p-5 mb-5" style="box-shadow:var(--shadow-soft)">
        <h3 class="font-700 mb-3 text-dark2">Tiến độ theo từng phần</h3>
        <div class="space-y-3">
          ${[['🔵 Phần 1 — Multiple Choice',progress.p1],['🟡 Phần 2 — Fill in the Blank',progress.p2],['🟣 Phần 3 — Mixed Mode',progress.p3],['🔴 Phần 4 — Master Test',progress.p4]].map(([label,p])=>`
          <div>
            <div class="flex justify-between text-xs font-600 mb-1 text-dark2"><span>${label}</span><span>${p}%</span></div>
            <div class="progress-bar"><div class="progress-fill" style="width:${p}%"></div></div>
          </div>`).join('')}
        </div>
      </div>

      <div class="surface rounded-2xl p-5 mb-5" style="box-shadow:var(--shadow-soft)">
        <h3 class="font-700 mb-3 text-dark2">Thành thạo theo chủ đề</h3>
        <div class="space-y-3">
          ${Object.keys(topicCounts).map(t=>{
            const m=masteredByTopic[t]||0;const c=topicCounts[t];const p=Math.round(m/c*100);
            return `<div>
              <div class="flex justify-between text-xs font-600 mb-1 text-dark2"><span>${t}</span><span>${m}/${c}</span></div>
              <div class="progress-bar"><div class="progress-fill" style="width:${p}%;background:linear-gradient(90deg,#9b5de5,#5e3aa6)"></div></div>
            </div>`;
          }).join('')}
        </div>
      </div>

      <div class="surface rounded-2xl p-5 mb-5 flex items-center justify-between" style="box-shadow:var(--shadow-soft)">
        <div>
          <h3 class="font-700 text-dark2">⭐ Từ yêu thích</h3>
          <p class="text-sm text-soft">${bookmarks.size} từ đã đánh dấu</p>
        </div>
        <button onclick="currentScreen='vocab';vocabFilterFav=true;render()" class="px-4 py-2 rounded-xl font-600 ripple-btn" style="background:var(--pink);color:var(--dark)">Xem ngay</button>
      </div>
    </div>
  </div>`;
  safeLucide();
}

// ===== INIT =====
async function init(){
  const saved = await loadAppState();
  if(saved){
    progress = saved.progress || progress;
    bestStreak = saved.bestStreak || 0;
    bookmarks = new Set(saved.bookmarks||[]);
    mastery = saved.mastery || {};
    soundOn = saved.soundOn !== undefined ? saved.soundOn : true;
    theme = saved.theme || 'light';
    totalAnswered = saved.totalAnswered || 0;
    totalCorrect = saved.totalCorrect || 0;
  }
  document.documentElement.setAttribute('data-theme',theme);
  render();
}

document.addEventListener('DOMContentLoaded', init);

  </script>
 </body>
