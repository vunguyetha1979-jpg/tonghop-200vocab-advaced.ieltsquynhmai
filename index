}

function loadMoreVocab(){
  vocabPage++;
  const filtered = applyVocabFilters();
  const newSlice = filtered.slice(
    VOCAB_PAGE_SIZE * vocabPage,
    VOCAB_PAGE_SIZE * (vocabPage + 1)
  );
  const container = document.getElementById('vocabContainer');
  if(container){
    const frag = document.createElement('div');
    frag.innerHTML = renderVocabCards(newSlice);
    container.appendChild(frag);
  }
  // Update count + load-more button
  const pageSliceLen = VOCAB_PAGE_SIZE * (vocabPage + 1);
  const shown = Math.min(pageSliceLen, filtered.length);
  const countEl = document.querySelector('.text-xs.text-soft.mb-3');
  if(countEl) countEl.textContent = `Tìm thấy ${filtered.length} từ — hiển thị ${shown}`;
  const moreArea = document.querySelector('.text-center.mt-4.mb-6, .text-center.text-xs.text-soft.mt-6.mb-4');
  if(moreArea){
    if(shown < filtered.length){
      moreArea.innerHTML = `<button onclick="loadMoreVocab()" class="btn-primary ripple-btn px-8">Xem thêm ${Math.min(VOCAB_PAGE_SIZE, filtered.length - shown)} từ nữa ↓</button>`;
    } else {
      moreArea.outerHTML = `<p class="text-center text-xs text-soft mt-6 mb-4">✅ Đã hiển thị tất cả ${filtered.length} từ</p>`;
    }
  }
}

