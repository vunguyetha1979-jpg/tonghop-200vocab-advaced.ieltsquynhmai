// ===== PART 1: MULTIPLE CHOICE =====
function generateMC(pool){
  gameQuestions=shuffle(pool).map(v=>{
    const wrongs=shuffle(VOCAB.filter(x=>x.id!==v.id)).slice(0,3);
    const opts=shuffle([v,...wrongs]);
    return{type:'mc',vocab:v,options:opts,correctId:v.id};
  });
}

// ===== PART 2: FILL IN BLANK =====
function generateFIB(pool){
  gameQuestions=shuffle(pool).map(v=>({type:'fib',vocab:v}));
}

// ===== PART 3: MIXED =====
function generateMixed(pool){
  const all=shuffle(pool);
  gameQuestions=[];
  all.forEach((v,i)=>{
    const mode=i%4;
    if(mode===0){
      const wrongs=shuffle(VOCAB.filter(x=>x.id!==v.id)).slice(0,3);
      const opts=shuffle([v,...wrongs]);
      gameQuestions.push({type:'mc',vocab:v,options:opts,correctId:v.id});
    }else if(mode===1){
      gameQuestions.push({type:'fib',vocab:v});
    }else if(mode===2){
      gameQuestions.push({type:'sentence',vocab:v});
    }else{
      const wrongs=shuffle(VOCAB.filter(x=>x.id!==v.id)).slice(0,3);
      const opts=shuffle([v,...wrongs]);
      gameQuestions.push({type:'mc_reverse',vocab:v,options:opts,correctId:v.id});
    }
  });
}

// ===== PART 4: MASTER =====
function generateMaster(pool){
  const all=shuffle(pool);
  gameQuestions=[];
  all.forEach((v,i)=>{
    const mode=i%2;
    if(mode===0){
      const wrongs=shuffle(VOCAB.filter(x=>x.id!==v.id)).slice(0,3);
      const opts=shuffle([v,...wrongs]);
      gameQuestions.push({type:'master_mc',vocab:v,options:opts,correctId:v.id});
    }else{
      gameQuestions.push({type:'sentence',vocab:v});
    }
  });
}

