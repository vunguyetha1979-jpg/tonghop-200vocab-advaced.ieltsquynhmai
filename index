function applyVocabFilters(){
  const t=vocabFilterText.toLowerCase();
  return VOCAB.filter(v=>{
    if(vocabFilterFav && !bookmarks.has(v.id)) return false;
    if(vocabFilterPos!=='all' && v.pos!==vocabFilterPos) return false;
    if(t && !(v.en.toLowerCase().includes(t) || v.vi.toLowerCase().includes(t) || v.enDef.toLowerCase().includes(t) || (v.example||'').toLowerCase().includes(t))) return false;
    return true;
  });
}

function renderVocabCards(list){
  if(list.length===0){
    return `<div class="empty-state"><div class="text-5xl mb-3">🔍</div><p class="text-dark2 font-600">Không tìm thấy từ phù hợp</p><p class="text-soft text-sm">Thử từ khoá khác hoặc bỏ bớt bộ lọc nhé.</p></div>`;
  }
  // Lazy-detail: collapsed summaries only; full card injected on first open
  return list.map((v, idx)=>`
  <div class="mb-3">
    <details ontoggle="lazyRenderDetail(this,${v.id})">
      <summary class="vocab-card card-hover cursor-pointer list-none" style="margin-bottom:0">
        <div class="flex items-start justify-between gap-2">
          <div class="flex-1 min-w-0">
            <div class="flex items-center flex-wrap gap-2 mb-1">
